# ── LangSmith 可观测性 ──────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="g-fund-agent"

# ── LLM 模型选择 ────────────────────────────────
# 可选值：deepseek | deepseek-reasoner | gemini | moonshot | minimax | ollama
# LLM_PROVIDER=ollama

# ── 且慢 MCP（基金数据源）─────────────────────────
QIEMAN_MCP_URL=https://stargate.yingmi.com/mcp/v2
QIEMAN_API_KEY=

# ── Deepseek ───────────────────────────────────
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── Google Gemini ──────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ── Kimi / Moonshot（OpenAI 兼容）───────────────
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.5

# ── MiniMax（Anthropic 兼容）────────────────────
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7

# ── Ollama（本地推理，无需 API Key）──────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:cloud
